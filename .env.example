# Google Cloud / TPU
GCP_PROJECT=your-project-id
TPU_ZONE=us-east5-a
TPU_VM_NAME=ssd-tpu-v6e-vm
TPU_SSH_HOST=
TPU_SSH_USER=
JAX_PLATFORMS=tpu

# Hugging Face (accept Gemma license at huggingface.co first)
HF_TOKEN=

# Model paths — target = larger verifier, draft = smaller speculator
# v6e-4 default: Gemma-2.2B target (3 chips) + Gemma-2B draft (1 chip)
TARGET_MODEL_PATH=./models/google_gemma-2-2b-it
DRAFT_MODEL_PATH=./models/google_gemma-2b-it
DATASET_CACHE=./data

# SSD algorithm defaults
SSD_K=4
SSD_FANOUT=2,2,2,2,2
SSD_SAMPLER_X=0.5
