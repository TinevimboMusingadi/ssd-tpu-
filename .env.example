# Google Cloud / TPU
GCP_PROJECT=your-project-id
TPU_ZONE=us-east5-a
TPU_VM_NAME=ssd-tpu-v6e-16-vm
TPU_SLICE_CHIPS=16
TPU_SSH_HOST=
TPU_SSH_USER=
JAX_PLATFORMS=tpu

# GCS — persistent model/dataset storage (survives VM teardown)
GCS_BUCKET=gs://your-project-id-ssd-tpu
GCS_MODEL_PREFIX=models

# Hugging Face (accept Gemma licenses on huggingface.co first)
HF_TOKEN=

# Model profile: sd-pair-7b | sd-pair-2b
MODEL_PROFILE=sd-pair-7b

# Model paths (gs:// or local cache after bootstrap sync)
TARGET_MODEL_PATH=gs://your-project-id-ssd-tpu/models/google_gemma-7b-it
DRAFT_MODEL_PATH=gs://your-project-id-ssd-tpu/models/google_gemma-2b-it
DATASET_CACHE=./data

# Sharding backend: flax | maxtext
SSD_SHARDING_BACKEND=flax

# SSD algorithm defaults
SSD_K=4
SSD_FANOUT=2,2,2,2,2
SSD_SAMPLER_X=0.5
